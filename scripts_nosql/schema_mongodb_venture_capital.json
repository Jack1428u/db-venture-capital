use("venture_capital");

db.createCollection("startups", {
    "capped": false,
    "validator": {
        "$jsonSchema": {
            "bsonType": "object",
            "title": "startups",
            "properties": {
                "_id": {
                    "bsonType": "objectId"
                },
                "startupId": {
                    "bsonType": "objectId"
                },
                "revenueReports": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "properties": {
                            "reportId": {
                                "bsonType": "objectId"
                            },
                            "reportMonth": {
                                "bsonType": "double"
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "reportId",
                            "reportMonth"
                        ]
                    }
                },
                "name": {
                    "bsonType": "string"
                },
                "description": {
                    "bsonType": "string"
                },
                "industry": {
                    "bsonType": "string"
                },
                "totalValuation": {
                    "bsonType": "double"
                },
                "status": {
                    "bsonType": "bool"
                },
                "createdAt": {
                    "bsonType": "date"
                },
                "admin": {
                    "bsonType": "object",
                    "properties": {
                        "adminId": {
                            "bsonType": "objectId"
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "adminId"
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "startupId",
                "name",
                "description",
                "industry",
                "totalValuation",
                "status",
                "createdAt"
            ]
        }
    },
    "validationLevel": "off",
    "validationAction": "warn"
});




db.createCollection("startups_details", {
    "capped": false,
    "validator": {
        "$jsonSchema": {
            "bsonType": "object",
            "title": "startups_details",
            "properties": {
                "_id": {
                    "bsonType": "objectId"
                },
                "fundingCampaings": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "properties": {
                            "fundingCampaignId": {
                                "bsonType": "objectId"
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "idStartup": {
                    "bsonType": "objectId"
                },
                "reviews": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "properties": {
                            "reviewId": {
                                "bsonType": "objectId"
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "reviewId"
                        ]
                    }
                },
                "founders": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "additionalProperties": false
                    }
                },
                "milestones": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "string"
                    }
                },
                "dividends": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "additionalProperties": false
                    }
                }
            },
            "additionalProperties": false,
            "required": [
                "idStartup"
            ]
        }
    },
    "validationLevel": "off",
    "validationAction": "warn"
});




db.createCollection("fundingCampaigns", {
    "capped": false,
    "validator": {
        "$jsonSchema": {
            "bsonType": "object",
            "title": "fundingCampaigns",
            "properties": {
                "_id": {
                    "bsonType": "objectId"
                },
                "fundingCampaignId": {
                    "bsonType": "objectId"
                },
                "startups": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "additionalProperties": false
                    }
                },
                "investors": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "properties": {
                            "investorId": {
                                "bsonType": "objectId"
                            }
                        },
                        "additionalProperties": false
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "validationLevel": "off",
    "validationAction": "warn"
});




db.createCollection("investors", {
    "capped": false,
    "validator": {
        "$jsonSchema": {
            "bsonType": "object",
            "title": "investors",
            "properties": {
                "_id": {
                    "bsonType": "objectId"
                },
                "investorId": {
                    "bsonType": "objectId"
                },
                "wallet": {
                    "bsonType": "object",
                    "properties": {
                        "walletId": {
                            "bsonType": "objectId"
                        },
                        "totalDeposited": {
                            "bsonType": "double"
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "walletId",
                        "totalDeposited"
                    ]
                },
                "shares": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "properties": {
                            "shareId": {
                                "bsonType": "objectId"
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "shareId"
                        ]
                    }
                },
                "transactions": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "properties": {
                            "methodType": {
                                "bsonType": "string",
                                "enum": [
                                    "card",
                                    "cash"
                                ]
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "methodType"
                        ]
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "validationLevel": "off",
    "validationAction": "warn"
});